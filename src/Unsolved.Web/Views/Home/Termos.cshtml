@{
    ViewData["Title"] = "Termos de uso";
    ViewData["Description"] = "Termos de uso da Unsolved (modelo). Condições gerais de uso do site institucional e da demonstração da plataforma.";
}

<section class="page-hero">
    <div class="container">
        <span class="section-tag">Legal</span>
        <h1>Termos de uso</h1>
        <p class="lead">Documento modelo, ilustrativo, sujeito a revisão jurídica antes de uso oficial.</p>
