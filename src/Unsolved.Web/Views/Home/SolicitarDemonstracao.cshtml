@{
    ViewData["Title"] = "Solicitar demonstração";
    ViewData["Description"] = "Solicite uma demonstração guiada da Unsolved e veja como a plataforma organiza casos, evidências e investigações.";
    ViewData["Source"] = "demonstracao";
}

<section class="page-hero">
    <div class="container">
        <span class="stamp-mini">EM INVESTIGAÇÃO</span>
        <h1>Solicitar demonstração</h1>
        <p class="lead">Conheça a plataforma em uma apresentação guiada, no contexto da sua equipe.</p>
    </div>
</section>

<section class="section">
    <div class="container demo-request-grid">
        <div class="reveal">
            <h2>O que esperar da demonstração</h2>
            <ul class="check-list">
                <li>Visão geral da plataforma e do fluxo de investigação</li>
                <li>Cadastro de casos, pessoas e evidências</li>
                <li>Linha do tempo e mural investigativo</li>
                <li>Controle de acesso, relatórios e painel de indicadores</li>
                <li>Espaço para dúvidas sobre segurança e implantação</li>
            </ul>
            <p class="disclaimer">Apresentação com dados fictícios. A Unsolved é uma ferramenta de apoio à investigação.</p>
        </div>

        <div class="contact-form-wrap reveal">
            <partial name="_ContactForm" />
        </div>
    </div>
</section>
