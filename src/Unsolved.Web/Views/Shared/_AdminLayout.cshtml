@{
    var title = ViewData["Title"] as string ?? "Painel";
    // Item de menu ativo (comparação simples pelo nome da action atual).
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    string Active(string a) => string.Equals(action, a, StringComparison.OrdinalIgnoreCase) ? "is-active" : "";
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title — Unsolved (Demonstração)</title>
    <meta name="robots" content="noindex" /> @* área demonstrativa: fora de indexação *@
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/animations.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <a class="skip-link" href="#admin-main">Pular para o conteúdo</a>

    @* ---- Barra lateral ---- *@
    <aside class="admin-sidebar" id="admin-sidebar">
        <a class="admin-brand" href="/sistema/painel">
            <img src="~/images/logo.png" alt="Unsolved" width="40" height="40" />
            <span>Unsolved</span>
        </a>

        <nav class="admin-nav" aria-label="Menu do sistema">
            <a class="@Active("Dashboard")" href="/sistema/painel">@Html.Raw(Icons.Svg("chart")) Painel</a>
            <a class="@Active("Cases")" href="/sistema/casos">@Html.Raw(Icons.Svg("folder")) Casos</a>
            <a class="@Active("Evidence")" href="/sistema/evidencias">@Html.Raw(Icons.Svg("box")) Evidências</a>
            <a class="@Active("People")" href="/sistema/pessoas">@Html.Raw(Icons.Svg("team")) Pessoas</a>
            <a class="@Active("Timeline")" href="/sistema/linha-do-tempo">@Html.Raw(Icons.Svg("timeline")) Linha do tempo</a>
            <a class="@Active("Board")" href="/sistema/mural">@Html.Raw(Icons.Svg("pin")) Mural</a>
            <a class="@Active("Reports")" href="/sistema/relatorios">@Html.Raw(Icons.Svg("report")) Relatórios</a>
            <a class="@Active("Settings")" href="/sistema/configuracoes">@Html.Raw(Icons.Svg("lock")) Configurações</a>
            <a class="@Active("Users")" href="/sistema/usuarios">@Html.Raw(Icons.Svg("key")) Usuários</a>
        </nav>

        <a class="admin-exit" href="/">← Voltar ao site</a>
    </aside>

    @* ---- Área principal ---- *@
    <div class="admin-shell">
        <header class="admin-topbar">
            <button class="admin-menu-toggle" id="admin-menu-toggle" aria-label="Abrir menu" aria-controls="admin-sidebar" aria-expanded="false">☰</button>
            <div class="admin-search">
                @Html.Raw(Icons.Svg("search"))
                <input type="search" placeholder="Buscar casos, pessoas, evidências…" aria-label="Buscar" />
            </div>
            <div class="admin-user">
                <span class="stamp-mini">DEMO</span>
                <span class="admin-avatar" aria-hidden="true">AM</span>
                <span class="admin-user-name">Insp. A. Marques</span>
            </div>
        </header>

        <main class="admin-main" id="admin-main">
            <div class="admin-breadcrumb">
                <span>Sistema</span> <span aria-hidden="true">/</span> <strong>@title</strong>
            </div>
            @RenderBody()
        </main>
    </div>

    <div class="demo-banner" role="note">
        Ambiente de <strong>demonstração</strong> com dados fictícios. Estrutura preparada para funcionalidades reais.
    </div>

    @* Lightbox para ampliar fotos de evidência (usado em toda a área do sistema). *@
    <div class="lightbox" id="lightbox" hidden>
        <button class="lightbox-close" aria-label="Fechar">&times;</button>
        <figure>
            <img id="lightbox-img" src="" alt="" />
            <figcaption id="lightbox-cap"></figcaption>
        </figure>
    </div>

    <script src="~/js/admin.js" asp-append-version="true" defer></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
