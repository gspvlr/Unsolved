@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Configurações";
}

<div class="admin-page-head">
    <h1>Configurações</h1>
    <span class="stamp-mini">PROTÓTIPO</span>
</div>

<div class="admin-cols">
    <section class="panel">
        <header class="panel-head"><h2>Organização</h2></header>
        <form class="admin-form" onsubmit="return false;">
            <div class="field"><label>Nome da organização</label><input type="text" value="Departamento de Investigação (exemplo)" /></div>
            <div class="field"><label>Fuso horário</label>
                <select><option>America/Sao_Paulo (GMT-3)</option><option>America/Manaus (GMT-4)</option></select>
            </div>
            <div class="field"><label>Prefixo de caso</label><input type="text" value="UNS" /></div>
            <button class="btn btn-primary btn-sm" type="button" disabled>Salvar</button>
        </form>
    </section>

    <section class="panel">
        <header class="panel-head"><h2>Preferências</h2></header>
        <ul class="toggle-list">
            <li><span>Notificações por e-mail</span><label class="switch"><input type="checkbox" checked disabled><span></span></label></li>
            <li><span>Registro de atividades (auditoria)</span><label class="switch"><input type="checkbox" checked disabled><span></span></label></li>
            <li><span>Exigir 2 fatores no acesso</span><label class="switch"><input type="checkbox" disabled><span></span></label></li>
            <li><span>Backups automáticos</span><label class="switch"><input type="checkbox" checked disabled><span></span></label></li>
        </ul>
        <p class="disclaimer">Preferências ilustrativas — recursos planejados.</p>
    </section>
</div>
