@model IReadOnlyList<PersonRoles>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Pessoas";
    string Tag(string role) => role switch { "Vítima" => "tag-vitima", "Suspeito" => "tag-suspeito", _ => "tag-testemunha" };
}

<div class="admin-page-head">
    <h1>Pessoas <span class="count-badge">@Model.Count</span></h1>
    <button class="btn btn-primary btn-sm" type="button" disabled title="Disponível na versão completa">+ Cadastrar pessoa</button>
</div>

<p class="muted" style="margin-bottom:18px">
    Registro único de pessoas (tabela <span class="mono">people</span>) reutilizado nos papéis de
    vítima, suspeito e testemunha. Quem aparece em mais de um caso é destacado.
</p>

<section class="panel">
    <header class="panel-head"><h2>Pessoas relacionadas</h2></header>
    <div class="people-grid">
        @foreach (var r in Model)
        {
            <article class="person-card">
                <span class="person-avatar" aria-hidden="true">@r.Person.FullName[0]</span>
                <div>
                    <strong>@r.Person.FullName</strong>
                    @foreach (var role in r.Roles)
                    {
                        <span class="tag @Tag(role)">@role</span>
                    }
                    @if (r.CaseAppearances > 1)
                    {
                        <span class="tag tag-primary">@r.CaseAppearances casos</span>
                    }
                    @if (!string.IsNullOrEmpty(r.Person.Notes)) { <p class="muted">@r.Person.Notes</p> }
                </div>
            </article>
        }
    </div>
</section>
