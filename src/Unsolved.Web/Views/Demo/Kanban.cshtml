@model IReadOnlyList<InvestigationCase>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Kanban";
    var columns = new[] { CaseStatus.Archived, CaseStatus.Reopening, CaseStatus.InProgress, CaseStatus.Solved };
}

<div class="admin-page-head">
    <h1>Kanban <span class="count-badge">@Model.Count</span></h1>
    <p class="muted">Arraste os cards entre as etapas · clique para abrir a tarefa.</p>
</div>

<div class="kanban" id="kanban">
    @foreach (var status in columns)
    {
        var cases = Model.Where(c => c.Status == status).OrderByDescending(c => c.CrimeOccurredOn).ToList();
        <section class="kanban-col" data-status="@status">
            <header class="kanban-col-head @DemoUi.StatusClass(status)">
                <span>@status</span>
                <span class="kanban-count">@cases.Count</span>
            </header>
            <div class="kanban-cards" data-dropzone>
                @foreach (var c in cases)
                {
                    <article class="kanban-card" draggable="true"
                             data-id="@c.Id"
                             data-code="@c.CaseCode"
                             data-title="@c.Title"
                             data-status="@c.Status"
                             data-statusclass="@DemoUi.StatusClass(c.Status)"
                             data-priority="@c.Priority"
                             data-prioclass="@DemoUi.PriorityClass(c.Priority)"
                             data-city="@c.City.Display"
                             data-date="@c.CrimeOccurredOn.ToString("dd/MM/yyyy")"
                             data-lead="@(c.Lead?.FullName ?? "Não atribuído")"
                             data-evid="@c.Evidences.Count"
                             data-susp="@c.Suspects.Count"
                             data-vict="@c.Victims.Count"
                             data-wit="@c.Witnesses.Count"
                             data-desc="@c.CrimeDescription">
                        <span class="kanban-prio prio @DemoUi.PriorityClass(c.Priority)" title="Prioridade: @c.Priority"></span>
                        <span class="kanban-code mono">@c.CaseCode</span>
                        <strong class="kanban-title">@c.Title</strong>
                        <span class="kanban-meta">@c.City.Display · @c.CrimeOccurredOn.ToString("dd/MM/yyyy")</span>
                        <span class="kanban-tags">
                            <span class="tag">@c.Evidences.Count evid.</span>
                            <span class="tag">@c.Suspects.Count susp.</span>
                        </span>
                    </article>
                }
                <p class="kanban-empty" hidden>Solte um card aqui.</p>
            </div>
        </section>
    }
</div>

@* Modal de "tarefa interna" — preenchido pelo kanban.js a partir do card clicado *@
<div class="task-modal" id="task-modal" hidden>
    <div class="task-modal-backdrop" data-close></div>
    <div class="task-modal-panel" role="dialog" aria-modal="true" aria-labelledby="tm-title">
        <button class="task-modal-close" data-close aria-label="Fechar">&times;</button>
        <span class="tm-code mono" id="tm-code"></span>
        <h2 id="tm-title"></h2>
        <div class="tm-badges">
            <span class="status-badge" id="tm-status"></span>
            <span class="prio" id="tm-prio"></span>
        </div>
        <dl class="tm-facts">
            <div><dt>Cidade</dt><dd id="tm-city"></dd></div>
            <div><dt>Ocorrido em</dt><dd id="tm-date"></dd></div>
            <div><dt>Responsável</dt><dd id="tm-lead"></dd></div>
        </dl>
        <div class="tm-stats">
            <span><strong id="tm-evid"></strong> evidências</span>
            <span><strong id="tm-vict"></strong> vítimas</span>
            <span><strong id="tm-susp"></strong> suspeitos</span>
            <span><strong id="tm-wit"></strong> testemunhas</span>
        </div>
        <h3>Descrição</h3>
        <p id="tm-desc"></p>
        <a class="btn btn-primary btn-sm" id="tm-open" href="#">Abrir caso completo →</a>
    </div>
</div>

@section Scripts {
    <script src="~/js/kanban.js" asp-append-version="true" defer></script>
}
