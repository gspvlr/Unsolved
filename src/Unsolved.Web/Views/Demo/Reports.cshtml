@model IReadOnlyList<InvestigationCase>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Relatórios";
    var m = ViewData["Metrics"] as DashboardMetrics;
    var today = DateTime.Today;

    // As consultas abaixo espelham database/03_queries.sql (as 10 do exercício).
    var q1 = Model.Where(c => c.Status != CaseStatus.Solved && c.CrimeOccurredOn < today.AddYears(-20))
                  .OrderBy(c => c.CrimeOccurredOn).ToList();
    var q2 = Model.OrderByDescending(c => c.Evidences.Count).ThenBy(c => c.CaseCode).ToList();
    var q3 = Model.Where(c => c.Status == CaseStatus.Archived)
                  .SelectMany(c => c.Suspects.Select(s => new { s.Person, c }))
                  .GroupBy(x => x.Person.Id)
                  .Select(g => new { g.First().Person, Cases = g.Select(x => x.c.CaseCode).Distinct().ToList() })
                  .Where(x => x.Cases.Count > 1).OrderByDescending(x => x.Cases.Count).ToList();
    var q4 = Model.SelectMany(c => c.Witnesses.Where(w => w.Reliability == "Alta").Select(w => new { c, w }))
                  .OrderBy(x => x.c.CaseCode).ToList();
    var q5 = Model.Where(c => c.Status == CaseStatus.Archived)
                  .GroupBy(c => c.City.Display)
                  .Select(g => new { City = g.Key, Count = g.Count() })
                  .OrderByDescending(x => x.Count).ToList();
    var q6 = Model.SelectMany(c => c.Evidences).Where(e => e.DiscoveredOn >= today.AddMonths(-6))
                  .OrderByDescending(e => e.DiscoveredOn).ToList();
    var q7 = Model.SelectMany(c => c.Evidences).Where(e => e.HasDna).OrderBy(e => e.Code).ToList();
    var q8 = Model.Where(c => c.Status == CaseStatus.Solved)
                  .SelectMany(c => c.Team.Select(t => new { t.Investigator, c }))
                  .GroupBy(x => x.Investigator.Id)
                  .Select(g => new { g.First().Investigator, Count = g.Select(x => x.c.Id).Distinct().Count() })
                  .OrderByDescending(x => x.Count).ToList();
    var topSuspect = Model.SelectMany(c => c.Suspects.Select(s => new { s.Person, c }))
                          .GroupBy(x => x.Person.Id)
                          .Select(g => new { g.First().Person, Cases = g.Select(x => x.c).ToList() })
                          .OrderByDescending(x => x.Cases.Count).FirstOrDefault();
    var q9 = topSuspect?.Cases.Where(c => c.Status != CaseStatus.Solved).ToList() ?? new();
    var victims = Model.SelectMany(c => c.Victims).ToList();
    var avgAge = victims.Where(v => v.AgeAtOccurrence.HasValue).Select(v => (double)v.AgeAtOccurrence!.Value).DefaultIfEmpty(0).Average();

    var byStatus = CaseStatus.All.Select(s => new { Status = s, Count = Model.Count(c => c.Status == s) }).ToList();
    var maxStatus = Math.Max(1, byStatus.Max(x => x.Count));
}

<div class="admin-page-head">
    <h1>Relatórios</h1>
    <span class="stamp-mini">CONSULTAS DO EXERCÍCIO</span>
</div>

<div class="kpi-grid">
    <div class="kpi-card"><span class="kpi-label">Casos</span><span class="kpi-num" data-counter="@(m?.TotalCases ?? 0)">0</span></div>
    <div class="kpi-card"><span class="kpi-label">Resolvidos</span><span class="kpi-num" data-counter="@(m?.SolvedCases ?? 0)">0</span></div>
    <div class="kpi-card"><span class="kpi-label">Evidências</span><span class="kpi-num" data-counter="@(m?.EvidenceItems ?? 0)">0</span></div>
    <div class="kpi-card"><span class="kpi-label">Idade média das vítimas</span><span class="kpi-num" data-counter="@((int)Math.Round(avgAge))">0</span></div>
</div>

<div class="admin-cols">
    <section class="panel">
        <header class="panel-head"><h2>Casos por status</h2></header>
        <div class="bar-chart">
            @foreach (var b in byStatus)
            {
                <div class="bar-row">
                    <span class="bar-label">@b.Status</span>
                    <div class="bar-track"><span class="bar-fill" style="width:@(b.Count * 100 / maxStatus)%"></span></div>
                    <span class="bar-value">@b.Count</span>
                </div>
            }
        </div>
    </section>

    <section class="panel">
        <header class="panel-head"><h2>5 · Cidades com mais casos arquivados</h2></header>
        <table class="data-table">
            <thead><tr><th>Cidade</th><th>Arquivados</th></tr></thead>
            <tbody>
                @foreach (var x in q5) { <tr><td>@x.City</td><td class="mono">@x.Count</td></tr> }
            </tbody>
        </table>
    </section>
</div>

<div class="admin-cols">
    <section class="panel">
        <header class="panel-head"><h2>1 · Não resolvidos há mais de 20 anos</h2></header>
        <table class="data-table">
            <thead><tr><th>Caso</th><th>Ocorrido</th><th>Status</th></tr></thead>
            <tbody>
                @foreach (var c in q1)
                {
                    <tr>
                        <td class="mono"><a href="/sistema/casos/@c.Id">@c.CaseCode</a></td>
                        <td>@c.CrimeOccurredOn.ToString("dd/MM/yyyy")</td>
                        <td><span class="status-badge @DemoUi.StatusClass(c.Status)">@c.Status</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </section>

    <section class="panel">
        <header class="panel-head"><h2>2 · Casos por nº de evidências</h2></header>
        <table class="data-table">
            <thead><tr><th>Caso</th><th>Título</th><th>Evid.</th></tr></thead>
            <tbody>
                @foreach (var c in q2.Take(6))
                {
                    <tr><td class="mono"><a href="/sistema/casos/@c.Id">@c.CaseCode</a></td><td>@c.Title</td><td class="mono">@c.Evidences.Count</td></tr>
                }
            </tbody>
        </table>
    </section>
</div>

<div class="admin-cols">
    <section class="panel">
        <header class="panel-head"><h2>3 · Suspeitos em vários casos arquivados</h2></header>
        <table class="data-table">
            <thead><tr><th>Suspeito</th><th>Casos</th></tr></thead>
            <tbody>
                @foreach (var x in q3) { <tr><td>@x.Person.FullName</td><td class="mono">@string.Join(", ", x.Cases)</td></tr> }
                @if (q3.Count == 0) { <tr><td colspan="2" class="muted">Nenhum.</td></tr> }
            </tbody>
        </table>
    </section>

    <section class="panel">
        <header class="panel-head"><h2>8 · Investigadores por casos resolvidos</h2></header>
        <table class="data-table">
            <thead><tr><th>Investigador</th><th>Resolvidos</th></tr></thead>
            <tbody>
                @foreach (var x in q8.Where(x => x.Count > 0)) { <tr><td>@x.Investigator.FullName</td><td class="mono">@x.Count</td></tr> }
            </tbody>
        </table>
    </section>
</div>

<div class="admin-cols">
    <section class="panel">
        <header class="panel-head"><h2>4 · Testemunhas de alta confiabilidade</h2></header>
        <table class="data-table">
            <thead><tr><th>Testemunha</th><th>Caso</th><th>Depoimento</th></tr></thead>
            <tbody>
                @foreach (var x in q4) { <tr><td>@x.w.Person.FullName</td><td class="mono">@x.c.CaseCode</td><td>@x.w.Statement</td></tr> }
            </tbody>
        </table>
    </section>
</div>

<div class="admin-cols">
    <section class="panel">
        <header class="panel-head"><h2>6 · Evidências dos últimos 6 meses</h2></header>
        <table class="data-table">
            <thead><tr><th>Código</th><th>Descoberta</th><th>Tipo</th></tr></thead>
            <tbody>
                @foreach (var e in q6) { <tr><td class="mono">@e.Code</td><td>@e.DiscoveredOn.ToString("dd/MM/yyyy")</td><td>@e.Type</td></tr> }
                @if (q6.Count == 0) { <tr><td colspan="3" class="muted">Nenhuma.</td></tr> }
            </tbody>
        </table>
    </section>

    <section class="panel">
        <header class="panel-head"><h2>7 · Evidências com análise de DNA</h2></header>
        <table class="data-table">
            <thead><tr><th>Código</th><th>Caso</th><th>Descrição</th></tr></thead>
            <tbody>
                @foreach (var e in q7) { <tr><td class="mono">@e.Code</td><td class="mono">@e.CaseCode</td><td>@e.Description</td></tr> }
            </tbody>
        </table>
    </section>
</div>

<div class="admin-cols">
    <section class="panel">
        <header class="panel-head"><h2>9 · Casos abertos de @(topSuspect?.Person.FullName ?? "—")</h2></header>
        <table class="data-table">
            <thead><tr><th>Caso</th><th>Título</th><th>Status</th></tr></thead>
            <tbody>
                @foreach (var c in q9)
                {
                    <tr><td class="mono"><a href="/sistema/casos/@c.Id">@c.CaseCode</a></td><td>@c.Title</td><td><span class="status-badge @DemoUi.StatusClass(c.Status)">@c.Status</span></td></tr>
                }
            </tbody>
        </table>
    </section>

    <section class="panel">
        <header class="panel-head"><h2>10 · Perfil das vítimas</h2></header>
        <p>Idade média na ocorrência: <strong>@avgAge.ToString("0.0")</strong> anos (@victims.Count vítimas).</p>
        <table class="data-table">
            <thead><tr><th>Ocupação</th><th>Qtd.</th></tr></thead>
            <tbody>
                @foreach (var g in victims.GroupBy(v => v.Occupation).OrderByDescending(g => g.Count()))
                {
                    <tr><td>@g.Key</td><td class="mono">@g.Count()</td></tr>
                }
            </tbody>
        </table>
    </section>
</div>

<p class="disclaimer">Consultas equivalentes a <span class="mono">database/03_queries.sql</span>, calculadas sobre os mesmos dados do seed.</p>
