@model IReadOnlyList<Evidence>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Evidências";
    var withDna = Model.Count(e => e.HasDna);
}

<div class="admin-page-head">
    <h1>Evidências <span class="count-badge">@Model.Count</span></h1>
    <button class="btn btn-primary btn-sm" type="button" disabled title="Disponível na versão completa">+ Cadastrar evidência</button>
</div>

<div class="kpi-grid">
    <div class="kpi-card"><span class="kpi-label">Total</span><span class="kpi-num" data-counter="@Model.Count">0</span></div>
    <div class="kpi-card"><span class="kpi-label">Em análise</span><span class="kpi-num" data-counter="@Model.Count(e => e.CustodyStatus == "Em análise")">0</span></div>
    <div class="kpi-card"><span class="kpi-label">Com análise de DNA</span><span class="kpi-num" data-counter="@withDna">0</span></div>
    <div class="kpi-card"><span class="kpi-label">Biológicas</span><span class="kpi-num" data-counter="@Model.Count(e => e.Type == "Biológica")">0</span></div>
</div>

<section class="panel">
    <header class="panel-head"><h2>Evidências cadastradas</h2></header>
    <table class="data-table">
        <thead><tr><th>Foto</th><th>Código</th><th>Caso</th><th>Descrição</th><th>Tipo</th><th>Custódia</th><th>Descoberta</th><th>Coletada por</th><th>Perícia</th></tr></thead>
        <tbody>
            @foreach (var e in Model)
            {
                <tr>
                    <td><img src="@e.ImagePath" class="ev-thumb-sm js-lightbox" data-full="@e.ImagePath" data-caption="@e.Code — @e.Description" alt="Foto @e.Code" loading="lazy" /></td>
                    <td class="mono">@e.Code</td>
                    <td class="mono"><a href="/sistema/casos/@e.CaseId">@e.CaseCode</a></td>
                    <td>@e.Description</td>
                    <td>@e.Type</td>
                    <td>@e.CustodyStatus</td>
                    <td>@e.DiscoveredOn.ToString("dd/MM/yyyy")</td>
                    <td>@(e.CollectedBy?.FullName ?? "—")</td>
                    <td>
                        @foreach (var a in e.Analyses)
                        {
                            <span class="tag tag-analysis">@a.Type</span>
                        }
                        @if (e.Analyses.Count == 0) { <span class="muted">—</span> }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <p class="empty-hint" hidden>Nenhuma evidência encontrada para esta busca.</p>
</section>
