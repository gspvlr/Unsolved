@model IReadOnlyList<InvestigationCase>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Painel";
    var m = ViewData["Metrics"] as DashboardMetrics;

    var recent = Model.OrderByDescending(c => c.OpenedOn).Take(6).ToList();
    // "Atividade" derivada do histórico de status real (case_status_history).
    var activity = Model
        .SelectMany(c => c.History.Select(h => new { c, h }))
        .OrderByDescending(x => x.h.ChangedAt)
        .Take(6)
        .ToList();
}

<div class="admin-page-head">
    <h1>Visão geral</h1>
    <a class="btn btn-primary btn-sm" href="/sistema/casos">Ver casos</a>
</div>

@* ---- KPIs (métricas do banco) ---- *@
<div class="kpi-grid">
    <div class="kpi-card"><span class="kpi-label">Casos totais</span><span class="kpi-num" data-counter="@(m?.TotalCases ?? 0)">0</span></div>
    <div class="kpi-card"><span class="kpi-label">Em aberto</span><span class="kpi-num" data-counter="@(m?.OpenCases ?? 0)">0</span></div>
    <div class="kpi-card"><span class="kpi-label">Resolvidos</span><span class="kpi-num" data-counter="@(m?.SolvedCases ?? 0)">0</span></div>
    <div class="kpi-card"><span class="kpi-label">Evidências</span><span class="kpi-num" data-counter="@(m?.EvidenceItems ?? 0)">0</span></div>
    <div class="kpi-card"><span class="kpi-label">Pessoas</span><span class="kpi-num" data-counter="@(m?.PeopleTracked ?? 0)">0</span></div>
    <div class="kpi-card"><span class="kpi-label">Investigadores</span><span class="kpi-num" data-counter="@(m?.Investigators ?? 0)">0</span></div>
</div>

<div class="admin-cols">
    <section class="panel">
        <header class="panel-head"><h2>Casos recentes</h2></header>
        <table class="data-table">
            <thead>
                <tr><th>Caso</th><th>Título</th><th>Cidade</th><th>Status</th><th>Progresso</th></tr>
            </thead>
            <tbody>
                @foreach (var c in recent)
                {
                    <tr>
                        <td class="mono"><a href="/sistema/casos/@c.Id">@c.CaseCode</a></td>
                        <td>@c.Title</td>
                        <td>@c.City.Display</td>
                        <td><span class="status-badge @DemoUi.StatusClass(c.Status)">@c.Status</span></td>
                        <td><div class="progress" title="@c.Progress%"><span style="width:@c.Progress%"></span></div></td>
                    </tr>
                }
            </tbody>
        </table>
    </section>

    <aside class="panel">
        <header class="panel-head"><h2>Atividade recente</h2></header>
        <ul class="activity">
            @foreach (var a in activity)
            {
                <li>
                    @if (a.h.By is not null) { <span class="lead-avatar activity-avatar">@Html.Raw(Avatars.Portrait(a.h.By.FullName))</span> }
                    <span class="mono">@a.h.ChangedAt.ToString("dd/MM/yyyy")</span>
                    <a href="/sistema/casos/@a.c.Id">@a.c.CaseCode</a> →
                    <strong>@a.h.NewStatus</strong>. @a.h.Reason
                </li>
            }
        </ul>
    </aside>
</div>
