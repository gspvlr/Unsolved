@model IReadOnlyList<InvestigationCase>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Linha do tempo";

    // Junta os eventos de todos os casos em uma linha do tempo única (mais recentes primeiro).
    var events = Model
        .SelectMany(c => c.Timeline.Select(t => new { Case = c, Event = t }))
        .OrderByDescending(x => x.Event.When)
        .ToList();
}

<div class="admin-page-head">
    <h1>Linha do tempo</h1>
    <p class="muted">Acontecimentos consolidados de todos os casos.</p>
</div>

<section class="panel">
    <ol class="case-timeline case-timeline-lg">
        @foreach (var x in events)
        {
            <li>
                <span class="tl-dot tl-@x.Event.Category.ToLower()" aria-hidden="true"></span>
                <div class="tl-content">
                    <span class="mono muted">@x.Event.When.ToString("dd/MM/yyyy")</span>
                    <a class="mono tl-case" href="/sistema/casos/@x.Case.Id">@x.Case.CaseNumber</a>
                    <strong>@x.Event.Title</strong>
                    <p>@x.Event.Description</p>
                    <span class="tag">@x.Event.Category</span>
                </div>
            </li>
        }
    </ol>
</section>
