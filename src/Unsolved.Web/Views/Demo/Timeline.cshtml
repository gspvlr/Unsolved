@model IReadOnlyList<InvestigationCase>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Linha do tempo";

    // Consolida o histórico de status (case_status_history) de todos os casos.
    var events = Model
        .SelectMany(c => c.History.Select(h => new { Case = c, Change = h }))
        .OrderByDescending(x => x.Change.ChangedAt)
        .ToList();
}

<div class="admin-page-head">
    <h1>Linha do tempo</h1>
    <p class="muted">Histórico de status consolidado de todos os casos (mais recentes primeiro).</p>
</div>

<section class="panel">
    <ol class="case-timeline case-timeline-lg">
        @foreach (var x in events)
        {
            <li>
                <span class="tl-dot" aria-hidden="true"></span>
                <div class="tl-content">
                    <span class="mono muted">@x.Change.ChangedAt.ToString("dd/MM/yyyy HH:mm")</span>
                    <a class="mono tl-case" href="/sistema/casos/@x.Case.Id">@x.Case.CaseCode</a>
                    <strong>@(x.Change.PreviousStatus is null ? "Abertura" : x.Change.PreviousStatus + " → ") @x.Change.NewStatus</strong>
                    <p>@x.Change.Reason</p>
                    @if (x.Change.By is not null) { <span class="tag">@x.Change.By.FullName</span> }
                </div>
            </li>
        }
    </ol>
</section>
