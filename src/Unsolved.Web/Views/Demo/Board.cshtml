@model IReadOnlyList<InvestigationCase>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Mural";
    var focus = Model.FirstOrDefault();
}

<div class="admin-page-head">
    <h1>Mural investigativo</h1>
    <p class="muted">Conecte pistas, pessoas e evidências. Protótipo visual.</p>
</div>

<section class="board">
    <div class="board-threads" aria-hidden="true"></div>

    @* Casos como notas fixadas *@
    @{ var rot = new[] { -2.5, 1.8, -1.2, 2.2 }; int i = 0; }
    @foreach (var c in Model)
    {
        <article class="pin-note" style="--rot:@rot[i % rot.Length]deg">
            <span class="note-pin" aria-hidden="true"></span>
            <span class="status-badge @DemoUi.StatusClass(c.Status)">@c.Status</span>
            <h3 class="mono">@c.CaseNumber</h3>
            <p>@c.Title</p>
            <a class="note-link" href="/sistema/casos/@c.Id">abrir caso →</a>
        </article>
        i++;
    }

    @if (focus is not null)
    {
        @* Fotos/evidências do caso em foco *@
        foreach (var e in focus.Evidences)
        {
            <article class="pin-photo" style="--rot:@rot[i % rot.Length]deg">
                <span class="note-pin" aria-hidden="true"></span>
                <div class="photo-frame" aria-hidden="true"></div>
                <span class="mono">@e.Code</span>
                <p>@e.Description</p>
            </article>
            i++;
        }
    }
</section>
