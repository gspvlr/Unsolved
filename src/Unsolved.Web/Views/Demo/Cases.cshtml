@model IReadOnlyList<InvestigationCase>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Casos";
}

<div class="admin-page-head">
    <h1>Casos <span class="count-badge">@Model.Count</span></h1>
    <button class="btn btn-primary btn-sm" type="button" disabled title="Disponível na versão completa">+ Novo caso</button>
</div>

@* Filtros por status (client-side). data-filter é lido por admin.js. *@
<div class="demo-filters admin-filters" role="group" aria-label="Filtrar por status">
    <button class="filter-chip is-active" data-filter="all">Todos</button>
    @foreach (var s in CaseStatus.All)
    {
        <button class="filter-chip" data-filter="@s">@s</button>
    }
</div>

<section class="panel">
    <table class="data-table js-filter-table">
        <thead>
            <tr><th>Caso</th><th>Título</th><th>Cidade</th><th>Ocorrido em</th><th>Status</th><th>Prioridade</th><th>Responsável</th><th>Evid.</th></tr>
        </thead>
        <tbody>
            @foreach (var c in Model.OrderByDescending(c => c.CrimeOccurredOn))
            {
                <tr data-status="@c.Status">
                    <td class="mono">
                        <a href="/sistema/casos/@c.Id" class="case-cell">
                            @if (c.CoverImage is not null)
                            {
                                <img src="@c.CoverImage" class="case-thumb" alt="" loading="lazy" />
                            }
                            <span>@c.CaseCode</span>
                        </a>
                    </td>
                    <td>@c.Title</td>
                    <td>@c.City.Display</td>
                    <td>@c.CrimeOccurredOn.ToString("dd/MM/yyyy")</td>
                    <td><span class="status-badge @DemoUi.StatusClass(c.Status)">@c.Status</span></td>
                    <td><span class="prio @DemoUi.PriorityClass(c.Priority)">@c.Priority</span></td>
                    <td>@(c.Lead?.FullName ?? "—")</td>
                    <td class="mono">@c.Evidences.Count</td>
                </tr>
            }
        </tbody>
    </table>
    <p class="empty-hint" hidden>Nenhum caso encontrado para este filtro.</p>
</section>
