@model IReadOnlyList<Investigator>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Investigadores";
    var cases = ViewData["Cases"] as IReadOnlyList<InvestigationCase> ?? new List<InvestigationCase>();

    int AssignedCount(int invId) => cases.Count(c => c.Team.Any(t => t.Investigator.Id == invId));
    int ResolvedCount(int invId) => cases.Count(c => c.Status == CaseStatus.Solved && c.Team.Any(t => t.Investigator.Id == invId));
}

<div class="admin-page-head">
    <h1>Investigadores <span class="count-badge">@Model.Count</span></h1>
    <button class="btn btn-primary btn-sm" type="button" disabled title="Disponível na versão completa">+ Convidar</button>
</div>

<div class="team-grid">
    @foreach (var i in Model.OrderByDescending(i => ResolvedCount(i.Id)))
    {
        <article class="team-card">
            <div class="team-avatar">@Html.Raw(Avatars.Portrait(i.FullName))</div>
            <h3>@i.FullName</h3>
            <span class="team-spec">@i.Specialty</span>
            <span class="team-badge mono">@i.Badge</span>
            <div class="team-stats">
                <span><strong>@AssignedCount(i.Id)</strong> casos</span>
                <span><strong>@ResolvedCount(i.Id)</strong> resolvidos</span>
            </div>
            @if (i.Active) { <span class="status-badge st-solved">Ativo</span> }
            else { <span class="status-badge st-cold">Inativo</span> }
        </article>
    }
</div>
