@model InvestigationCase
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = Model.CaseCode;
}

<div class="admin-page-head">
    <a class="back-link" href="/sistema/casos">← Casos</a>
</div>

@* ---- Cabeçalho do caso (dossiê) ---- *@
<section class="case-hero">
    <div class="case-hero-cover">
        @if (Model.CoverImage is not null)
        {
            <img src="@Model.CoverImage" alt="Foto do caso @Model.CaseCode" loading="lazy"
                 class="js-lightbox" data-full="@Model.CoverImage" data-caption="@Model.CaseCode — capa do caso" />
        }
        <span class="case-stamp @DemoUi.StatusClass(Model.Status)">@Model.Status</span>
    </div>
    <div class="case-hero-facts">
        <span class="mono case-code">@Model.CaseCode</span>
        <h1>@Model.Title</h1>
        <p class="case-desc">@Model.CrimeDescription</p>
        <div class="case-meta">
            <div><span class="muted">Cidade</span><strong>@Model.City.Display</strong></div>
            <div><span class="muted">Prioridade</span><strong><span class="prio @DemoUi.PriorityClass(Model.Priority)">@Model.Priority</span></strong></div>
            <div><span class="muted">Ocorrido em</span><strong>@Model.CrimeOccurredOn.ToString("dd/MM/yyyy")</strong></div>
            <div><span class="muted">Aberto em</span><strong>@Model.OpenedOn.ToString("dd/MM/yyyy")</strong></div>
            <div><span class="muted">Encerrado em</span><strong>@(Model.ClosedOn?.ToString("dd/MM/yyyy") ?? "—")</strong></div>
            <div><span class="muted">Responsável</span><strong>@(Model.Lead?.FullName ?? "—")</strong></div>
        </div>
        <div class="progress progress-lg" title="@Model.Progress%"><span style="width:@Model.Progress%"></span></div>
    </div>
</section>

@* ---- Resumo numérico ---- *@
<div class="stat-row">
    <div class="stat-chip"><strong>@Model.Evidences.Count</strong><span>Evidências</span></div>
    <div class="stat-chip"><strong>@Model.Victims.Count</strong><span>Vítimas</span></div>
    <div class="stat-chip"><strong>@Model.Suspects.Count</strong><span>Suspeitos</span></div>
    <div class="stat-chip"><strong>@Model.Witnesses.Count</strong><span>Testemunhas</span></div>
    <div class="stat-chip"><strong>@Model.Evidences.SelectMany(e => e.Analyses).Count()</strong><span>Perícias</span></div>
    <div class="stat-chip"><strong>@Model.Team.Count</strong><span>Equipe</span></div>
</div>

@* ---- Galeria de evidências (fotos) ---- *@
<section class="panel">
    <header class="panel-head"><h2>Evidências e fotos (@Model.Evidences.Count)</h2><span class="stamp-mini">CADEIA DE CUSTÓDIA</span></header>
    <div class="ev-gallery">
        @foreach (var e in Model.Evidences)
        {
            <figure class="ev-card">
                <button class="ev-thumb js-lightbox" data-full="@e.ImagePath"
                        data-caption="@e.Code — @e.Description" aria-label="Ampliar @e.Code">
                    <img src="@e.ImagePath" alt="Foto da evidência @e.Code" loading="lazy" />
                    <span class="ev-type">@e.Type</span>
                    @if (e.HasDna) { <span class="ev-dna">DNA</span> }
                </button>
                <figcaption>
                    <strong class="mono">@e.Code</strong>
                    <p>@e.Description</p>
                    <p class="muted mono">@e.CustodyStatus · @e.DiscoveredOn.ToString("dd/MM/yyyy")</p>
                    @foreach (var a in e.Analyses)
                    {
                        <span class="tag tag-analysis">@a.Type · @a.Status</span>
                    }
                </figcaption>
            </figure>
        }
    </div>
</section>

<div class="admin-cols">
    <section class="panel">
        <header class="panel-head"><h2>Vítimas (@Model.Victims.Count)</h2></header>
        <ul class="people-list">
            @foreach (var v in Model.Victims)
            {
                <li>
                    <span class="person-avatar" aria-hidden="true">@v.Person.FullName[0]</span>
                    <div>
                        <strong>@v.Person.FullName</strong> <span class="tag tag-vitima">Vítima</span>
                        <p class="muted">@v.Occupation@(v.AgeAtOccurrence is null ? "" : $" · {v.AgeAtOccurrence} anos na época")</p>
                        <p class="muted">@v.Relationship</p>
                    </div>
                </li>
            }
        </ul>
    </section>

    <section class="panel">
        <header class="panel-head"><h2>Suspeitos (@Model.Suspects.Count)</h2></header>
        <ul class="people-list">
            @foreach (var s in Model.Suspects)
            {
                <li>
                    <span class="person-avatar" aria-hidden="true">@s.Person.FullName[0]</span>
                    <div>
                        <strong>@s.Person.FullName</strong>
                        <span class="tag tag-suspeito">Suspeito</span>
                        @if (s.IsPrimary) { <span class="tag tag-primary">Principal</span> }
                        @if (!string.IsNullOrEmpty(s.Alias)) { <span class="muted">vulgo "@s.Alias"</span> }
                        <p class="muted">@s.LinkToCrime</p>
                        @if (!string.IsNullOrEmpty(s.CriminalHistory)) { <p class="muted"><strong>Histórico:</strong> @s.CriminalHistory</p> }
                    </div>
                </li>
            }
        </ul>
    </section>
</div>

<div class="admin-cols">
    <section class="panel">
        <header class="panel-head"><h2>Testemunhas (@Model.Witnesses.Count)</h2></header>
        <ul class="people-list">
            @foreach (var w in Model.Witnesses)
            {
                <li>
                    <span class="person-avatar" aria-hidden="true">@w.Person.FullName[0]</span>
                    <div>
                        <strong>@w.Person.FullName</strong>
                        <span class="tag tag-rel-@w.Reliability.ToLower()">Confiabilidade @w.Reliability</span>
                        <p class="muted">“@w.Statement”</p>
                        <p class="muted mono">Registrado em @w.RecordedOn.ToString("dd/MM/yyyy")</p>
                    </div>
                </li>
            }
        </ul>
    </section>

    <section class="panel">
        <header class="panel-head"><h2>Equipe (@Model.Team.Count)</h2></header>
        <ul class="people-list">
            @foreach (var t in Model.Team.OrderByDescending(t => t.IsLead))
            {
                <li>
                    <span class="person-avatar" aria-hidden="true">@t.Investigator.FullName[0]</span>
                    <div>
                        <strong>@t.Investigator.FullName</strong>
                        @if (t.IsLead) { <span class="tag tag-primary">Responsável</span> }
                        <p class="muted">@t.Investigator.Specialty · @t.Investigator.Badge</p>
                        <p class="muted mono">@t.AssignedOn.ToString("dd/MM/yyyy") — @(t.ReleasedOn?.ToString("dd/MM/yyyy") ?? "atual")</p>
                    </div>
                </li>
            }
        </ul>
    </section>
</div>

<section class="panel">
    <header class="panel-head"><h2>Histórico de status</h2></header>
    <ol class="case-timeline">
        @foreach (var h in Model.History.OrderBy(x => x.ChangedAt))
        {
            <li>
                <span class="tl-dot" aria-hidden="true"></span>
                <div class="tl-content">
                    <span class="mono muted">@h.ChangedAt.ToString("dd/MM/yyyy HH:mm")</span>
                    <strong>@(h.PreviousStatus is null ? "Abertura" : h.PreviousStatus + " → ")@h.NewStatus</strong>
                    <p>@h.Reason</p>
                    @if (h.By is not null) { <span class="tag">@h.By.FullName</span> }
                </div>
            </li>
        }
    </ol>
</section>

